{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/artifact-lifecycle.schema.v1.json",
  "title": "ArtifactLifecycleV1",
  "description": "Public artifact version-chain contract.",
  "type": "object",
  "required": [
    "artifact_id",
    "logical_key",
    "version_no",
    "parent_artifact_id",
    "sha1",
    "trace_id",
    "visibility"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "logical_key": {
      "type": "string",
      "minLength": 1
    },
    "version_no": {
      "type": "integer",
      "minimum": 1
    },
    "parent_artifact_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "sha1": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "visibility": {
      "type": "string",
      "enum": ["internal", "session", "user"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "final", "superseded", "blocked"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "visibility": { "const": "user" }
        },
        "required": ["visibility"]
      },
      "then": {
        "required": ["message_id"]
      }
    }
  ],
  "examples": [
    {
      "artifact_id": "art-9f21",
      "logical_key": "answer/main",
      "version_no": 2,
      "parent_artifact_id": "art-9f20",
      "sha1": "15f53b9d3f8a3d9a2cb6ff9776ebf1e2f2dca4a5",
      "trace_id": "trc-001",
      "run_id": "run-001",
      "session_id": "sess-001",
      "message_id": "msg-030",
      "visibility": "user",
      "status": "final",
      "created_at": "2026-03-06T10:00:00Z"
    },
    {
      "artifact_id": "art-0001",
      "logical_key": "checkpoint/diagnosis",
      "version_no": 1,
      "parent_artifact_id": null,
      "sha1": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "trace_id": "trc-min",
      "visibility": "session",
      "status": "draft",
      "created_at": "2026-03-06T10:05:00Z"
    }
  ],
  "additionalProperties": false
}
