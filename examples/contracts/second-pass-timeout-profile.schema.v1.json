{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/second-pass-timeout-profile.schema.v1.json",
  "title": "SecondPassTimeoutProfileV1",
  "description": "Resolved timeout profile for second-pass execution.",
  "type": "object",
  "required": [
    "level",
    "score",
    "base_seconds",
    "resolved_seconds",
    "max_seconds",
    "factors"
  ],
  "properties": {
    "level": {
      "type": "string",
      "enum": ["low", "medium", "high", "extreme", "critical"]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "base_seconds": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "resolved_seconds": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Resolver must ensure resolved_seconds <= max_seconds."
    },
    "max_seconds": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "factors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": ["factor", "weight", "delta_seconds"],
            "properties": {
              "factor": {
                "type": "string",
                "minLength": 1
              },
              "weight": {
                "type": "number",
                "minimum": 0
              },
              "delta_seconds": {
                "type": "number"
              },
              "note": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "examples": [
    {
      "level": "high",
      "score": 0.79,
      "base_seconds": 18,
      "resolved_seconds": 34,
      "max_seconds": 45,
      "factors": [
        "token:1850",
        "domain:DISTRIBUTED+0.20",
        "diagnosis:structure+0.05"
      ]
    },
    {
      "level": "extreme",
      "score": 1,
      "base_seconds": 30,
      "resolved_seconds": 60,
      "max_seconds": 60,
      "factors": [
        "token:9200",
        "policy_cap"
      ]
    }
  ],
  "additionalProperties": false
}
