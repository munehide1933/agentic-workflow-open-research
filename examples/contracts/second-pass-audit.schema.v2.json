{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/second-pass-audit.schema.v2.json",
  "title": "SecondPassAuditV2",
  "type": "object",
  "required": [
    "counter_hypotheses",
    "missing_evidence",
    "unsafe_recommendations",
    "structure_inconsistencies",
    "audit_completeness"
  ],
  "properties": {
    "counter_hypotheses": {
      "type": "array",
      "minItems": 0,
      "items": { "type": "string", "minLength": 1 }
    },
    "missing_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "unsafe_recommendations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "structure_inconsistencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "audit_completeness": {
      "type": "string",
      "enum": ["full", "partial", "invalid"]
    }
  },
  "additionalProperties": false
}
