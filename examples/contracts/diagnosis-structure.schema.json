{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/diagnosis-structure.schema.json",
  "title": "DiagnosisStructure",
  "description": "Structured diagnosis output artifact. This schema models output fields generated by diagnosis stage, not request input validation.",
  "$comment": "`required_fields` enumerates missing observations needed to raise confidence in diagnosis output.",
  "type": "object",
  "required": [
    "facts",
    "hypotheses",
    "excluded_hypotheses",
    "insufficient_evidence",
    "required_fields"
  ],
  "properties": {
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fact", "source"],
        "properties": {
          "fact": { "type": "string", "minLength": 1 },
          "evidence_span": { "type": "string" },
          "evidence_keys": {
            "type": "array",
            "items": { "type": "string" }
          },
          "source": {
            "type": "string",
            "enum": ["log", "user_text", "system_state"]
          }
        },
        "additionalProperties": false
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["hypothesis", "confidence", "test", "rank", "is_primary_candidate"],
        "properties": {
          "hypothesis": { "type": "string", "minLength": 1 },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "test": { "type": "string", "minLength": 1 },
          "rank": { "type": "integer", "minimum": 1 },
          "is_primary_candidate": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "excluded_hypotheses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "insufficient_evidence": { "type": "boolean" },
    "required_fields": {
      "type": "array",
      "description": "Output-only list of additional observations needed to improve diagnosis confidence. This field may be empty when evidence is sufficient.",
      "$comment": "Not request input validation fields.",
      "items": { "type": "string" }
    }
  },
  "examples": [
    {
      "facts": [
        {
          "fact": "latency spike observed after deployment",
          "source": "log",
          "evidence_keys": ["p95_latency", "deploy_ts"]
        }
      ],
      "hypotheses": [
        {
          "hypothesis": "connection pool saturation",
          "confidence": "medium",
          "test": "compare active connections against pool max",
          "rank": 1,
          "is_primary_candidate": true
        }
      ],
      "excluded_hypotheses": ["dns outage"],
      "insufficient_evidence": false,
      "required_fields": []
    },
    {
      "facts": [
        {
          "fact": "error rate increased",
          "source": "user_text"
        }
      ],
      "hypotheses": [
        {
          "hypothesis": "upstream timeout",
          "confidence": "low",
          "test": "collect upstream timeout counters per endpoint",
          "rank": 1,
          "is_primary_candidate": false
        }
      ],
      "excluded_hypotheses": [],
      "insufficient_evidence": true,
      "required_fields": [
        "upstream timeout metrics by endpoint",
        "recent deployment diff",
        "runtime and SDK version"
      ]
    }
  ],
  "additionalProperties": false
}
